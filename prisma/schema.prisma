generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Prompt {
  id             String  @id @default(cuid())
  clerkUserId    String
  title          String
  content        String  @db.Text
  formData       Json?
  version        Int     @default(1)
  rootPromptId   String?
  parentPromptId String?

  rootPrompt    Prompt?  @relation("PromptVersions", fields: [rootPromptId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  versions      Prompt[] @relation("PromptVersions")
  parentPrompt  Prompt?  @relation("PromptParent", fields: [parentPromptId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  childVersions Prompt[] @relation("PromptParent")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkUserId, createdAt])
  @@index([rootPromptId, version])
}
